---
const links: Record<string, string>[] = [
   {
      href: 'about',
      link: 'About',
   },
   {
      href: 'contact',
      link: 'Contact',
   },
];
---

<div class="flex flex-col items-start gap-y-0.5">
   <p
      class="text-neutral-600 tracking-tight text-sm lg:text-base mb-1 font-light"
   >
      Navigation
   </p>
   {
      links.map((link) => (
         <a
            href={link.href}
            class="tracking-tight font-normal text-sm lg:text-base py-1 transition text-white duration-150 ease-linear -ml-3 px-3 rounded-full outline-none focus:bg-blue-500/5 focus:text-blue-500 hover:bg-blue-500/5 hover:text-blue-500"
         >
            {link.link}
         </a>
      ))
   }
</div>
